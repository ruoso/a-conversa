# Node
node_modules/
*.log
logs/

# Build outputs (TS/Node + Vite-resolution conventions; React frontend)
dist/
build/

# TypeScript incremental build info
*.tsbuildinfo

# Coverage
coverage/
.nyc_output/

# Test artifacts
playwright-report/
test-results/
tests/e2e/.auth/

# Package manager caches
# Currently on pnpm (per pnpm-lock.yaml at root); npm and yarn caches are
# kept here speculatively to keep stray installs out of the index.
.pnpm-store/
.npm/
.yarn/

# Environment files
# Note: .env.example is intentionally checked in (template); see
# foundation.dev_env.env_var_template.
.env
.env.local
.env.*.local

# IDE / editor local state
# Default position: ignore the whole .vscode/ tree. Downstream tasks may
# carve out shared files (e.g., .vscode/launch.json, .vscode/settings.json)
# with explicit !-rules if/when they're committed.
.vscode/*
.idea/
.DS_Store
*.swp
.antigravitycli/

# TaskJuggler generated reports (written to the `report/` directory via the
# project's `outputdir` setting in project.tjp). Scoped to that directory
# only — do NOT ignore *.html globally, since downstream docs/static assets
# may legitimately ship HTML. The directory itself is kept in the tree via a
# `.gitkeep` sentinel so tj3 has a place to write to on a fresh checkout.
report/*
!report/.gitkeep

# Temp tjp written by `scripts/unblocked.ts` (cleaned up in normal runs,
# but ignore it so an aborted run doesn't pollute git status).
.unblocked-report.tjp

# Local-dev compose stack
# Placeholder: data-volume mounts (e.g., a `data/` directory for the
# Postgres container) will be added when foundation.dev_env.compose_file
# lands and the volume layout is fixed.

# Authelia container scratch state (ad-hoc verification runs that bind
# a host directory in place of the Compose-managed volume). The
# Compose stack uses a named volume; this entry covers the bare-docker
# smoke-test path documented in infra/authelia/README.md.
infra/authelia/data/
infra/authelia/db.sqlite3
infra/authelia/notifications.txt

# Ephemeral sub-agent worktrees (local-only). Tools spawn isolated git
# worktrees here for parallel investigation; they must never end up in
# the index of the main branch.
.claude/

# Python virtualenvs (used by the orchestrator/ driver — see
# orchestrator/README.md). The venv is local-only and currently has no
# pinned dependencies (the driver is stdlib-only).
.venv/
__pycache__/
*.pyc
