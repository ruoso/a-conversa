# 50 — Audience and broadcast
#
# The read-only audience surface — rendered for video, served as an OBS
# browser source for live shows. The "this is the show" surface.
#
# i18n note
# ---------
# All user-facing strings in this surface land via the i18n catalog
# substrate built by `frontend_i18n` (see tasks/35-frontend-i18n.tji
# and docs/adr/0024-frontend-i18n-react-i18next-with-icu.md). Three
# refinements under tasks/refinements/frontend-i18n/ are load-bearing:
#   - i18n_catalog_workflow.md
#   - i18n_methodology_glossary.md       — for node + edge labels
#   - i18n_diagnostic_descriptions.md    — for diagnostic-fire captions
# Audience locale is URL-prefix-driven (per i18n_locale_negotiation.md):
# `/{locale}/sessions/{id}` lets the producer choose the locale via the
# URL pointed at OBS. Diacritic + typography validation is owned by
# i18n_audience_typography.md, which gates on aud_clean_typography.

task audience "Audience and broadcast" {
  # Every audience-UI leaf inherits this dependency. Public-session
  # paths are unauthenticated by design (see `aud_no_auth_for_public`),
  # but the private-session path goes through the same OIDC handshake
  # the moderator + participant surfaces do — and the broadcast
  # surface itself sits behind the same auth layer until a session is
  # promoted to public. `auth_flow_integration` is the canonical home
  # for the end-to-end OIDC handshake tests; nothing in this stream
  # should ship without that safety net.
  depends backend.backend_tests.be_e2e_tests.auth_flow_integration
  task aud_shell "Audience app shell" {
    depends foundation.repo_skeleton, foundation.stack_decisions.frontend_framework_decision
    task aud_app_skeleton "Audience surface as a mountable library (entry, build, mount() export)" {
      effort 1d
      allocate team
      complete 100
      depends shell_package.shell_mount_contract, frontend_i18n.i18n_locale_negotiation
      note -8<-
        Refinement: tasks/refinements/audience/aud_app_skeleton.md

        Reshaped under ADR 0026: audience builds as a Vite-library bundle exporting mount(props): UnmountFn; no own index.html or DOM bootstrap. i18n now bootstraps in @aconversa/shell and is passed in via MountProps (locale negotiation still uses the URL prefix per i18n_locale_negotiation.md; the audience surface reads its locale from the URL and configures the shared i18n instance accordingly).

        Locale comes from URL prefix per i18n_locale_negotiation.md; under ADR 0026 the per-session prefix becomes /a/sessions/:id, with the locale segment handled inside the audience surface's basename-scoped routes.
      ->8-
    }
    task aud_ws_client "Wire audience surface to shell's WS client (read-only subscription)" {
      effort 0.5d
      allocate team
      complete 100
      depends !aud_app_skeleton, shell_package.shell_substrate_extraction, backend.websocket_protocol.ws_subscribe_to_session
      note "Reshaped under ADR 0026: the underlying WS client implementation lives in @aconversa/shell. This leaf wires the audience surface's read-only subscription path to the shared client (was: re-implementing the WS client inside the audience workspace, 1d)."
    }
    task aud_state_management "State management for live event stream" {
      effort 1d
      allocate team
      complete 100
      depends !aud_ws_client
    }
    task aud_no_auth_for_public "No auth for public-session viewer page" {
      effort 0.5d
      allocate team
      complete 100
      depends !aud_app_skeleton
      note -8<-
        Public sessions render to anyone with the URL; private sessions auth-gate.

        Refinement: tasks/refinements/audience/aud_no_auth_for_public.md
      ->8-
    }
    task aud_anonymous_ws_subscribe "Server-side anonymous WS subscribe with per-session privacy enforcement" {
      effort 0.5d
      allocate team
      complete 100
      depends !aud_no_auth_for_public, backend.websocket_protocol.ws_subscribe_to_session
      note "Server-side anonymous WS subscribe with per-session privacy enforcement. Audience surface for anonymous visitors mounts the placeholder but `<WsClientProvider>` short-circuits without opening a socket until this leaf lands (the cookie-on-upgrade gate at `apps/server/src/ws/connection.ts:86-104` requires an authenticated session today). Source: tasks/refinements/audience/aud_no_auth_for_public.md (Decision §9) + this commit."
    }
    task aud_auth_for_private "Wire audience surface to shell's AuthContext for private sessions" {
      effort 0.5d
      allocate team
      complete 100
      depends !aud_no_auth_for_public, shell_package.shell_substrate_extraction
      note "Reshaped under ADR 0026: the OAuth callback handling, login/logout, and screen-name capture all live in apps/root/ + @aconversa/shell. The audience surface only consumes useAuth() from shell to auth-gate private-session viewer pages; the auth UX itself is the root's responsibility."
    }
  }

  task aud_graph_rendering "Audience graph rendering (Cytoscape.js)" {
    depends !aud_shell, foundation.stack_decisions.graph_lib_decision
    task aud_cytoscape_init "Initialize Cytoscape.js viewport" {
      effort 1d
      allocate team
      complete 100
      note -8<-
        Refinement: tasks/refinements/audience/aud_cytoscape_init.md

        Ships <AudienceGraphView> (Cytoscape.js mount, breadthfirst layout, dangling-edge filter,
        position cache, cyRef callback seam), pure projectGraph() projection, and duplicated
        cytoscapeTestEnv helper. 26 Vitest cases (10 projection + 12 GraphView + 4 cytoscapeTestEnv).
        App.tsx and route table unchanged; Playwright deferred to aud_session_url (Decision §9).
      ->8-
    }
    task aud_clean_typography "Clean typography for video legibility" {
      effort 1d
      allocate team
      complete 100
      depends !aud_cytoscape_init
      note -8<-
        Refinement: tasks/refinements/audience/aud_clean_typography.md

        Inter (Google Fonts, display=swap) wired into the audience surface CSS via Tailwind v4
        --font-broadcast, and into Cytoscape's STYLESHEET for node (14px / 600) and edge (11px / 500)
        labels via BROADCAST_FONT_STACK. Four named exports (BROADCAST_NODE_FONT_SIZE_PX,
        BROADCAST_EDGE_FONT_SIZE_PX, BROADCAST_NODE_FONT_WEIGHT, BROADCAST_EDGE_FONT_WEIGHT) land
        alongside STYLESHEET for sibling-task reuse. 6 new Vitest cases (22 total) pin the
        typography surface. Playwright deferred to aud_visual_regression (Decision §6).
      ->8-
    }
    task aud_proposed_styling "Proposed-state styling (dashed, faded)" {
      effort 1d
      allocate team
      complete 100
      depends !aud_cytoscape_init
      note -8<-
        Refinement: tasks/refinements/audience/aud_proposed_styling.md

        Fourth verbatim facetStatus.ts port (server + moderator + participant + audience).
        AudienceNodeData/EdgeData extended with facetStatuses + rollupStatus; projectGraph
        calls computeFacetStatuses once up-front and stamps both fields onto every emitted
        descriptor ('none' sentinel for entities with no facet events). Two new STYLESHEET
        selector entries: node[rollupStatus = 'proposed'] → border-style 'dashed' + opacity 0.6
        and edge[rollupStatus = 'proposed'] → line-style 'dashed' + opacity 0.6. 4 new
        GraphView.test.tsx cases (y–bb: 2 structural + 2 mount-time); 6 new projectGraph cases
        (k–p). Playwright deferred to aud_visual_regression per Decision §6.
        Tech-debt: extract_facet_status_rules (tasks/27-shell-package.tji:79) consolidates the
        four copies once audience.aud_graph_rendering completes.
      ->8-
    }
    task aud_agreed_styling "Agreed-state styling (solid, full color)" {
      effort 0.5d
      allocate team
      complete 100
      depends !aud_cytoscape_init, !aud_proposed_styling
      note -8<-
        Refinement: tasks/refinements/audience/aud_agreed_styling.md

        Two new STYLESHEET selector entries: node[rollupStatus = 'agreed'] → border-color #334155
        (slate-700) and edge[rollupStatus = 'agreed'] → line-color + target-arrow-color #334155.
        Header trail + STYLESHEET JSDoc extended. Two structural Vitest cases (w, x) added;
        mount-time cases deferred to aud_agreed_styling_mount_assertions (needs aud_proposed_styling
        projection-time emission). Playwright deferred to aud_visual_regression per Decision §5.
        depends !aud_proposed_styling added per Decision §1 / Acceptance criteria.
      ->8-
    }
    task aud_disputed_styling "Disputed-state styling" {
      effort 1d
      allocate team
      complete 100
      depends !aud_cytoscape_init, !aud_proposed_styling
      note -8<-
        Refinement: tasks/refinements/audience/aud_disputed_styling.md

        Two new STYLESHEET selector entries: node[rollupStatus = 'disputed'] → border-color #e11d48
        (rose-600) + border-width 3 (first per-state border-width override); edge[rollupStatus =
        'disputed'] → line-color + target-arrow-color #e11d48. Header trail + STYLESHEET JSDoc
        extended. Four new Vitest cases (ee–hh: 2 structural + 2 mount-time) land inline; mount-time
