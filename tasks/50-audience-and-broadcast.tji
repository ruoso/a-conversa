    task aud_annotation_rendering "Annotation rendering" {
      effort 1d
      allocate team
      complete 100
      depends !aud_cytoscape_init
      note -8<-
        Refinement: tasks/refinements/audience/aud_annotation_rendering.md

        Per-annotation amber pill badges rendered as a third DOM-overlay sibling of the Cytoscape
        canvas. annotations.ts port (projectAnnotations + groupAnnotationsByNode + Annotation +
        EMPTY_ANNOTATIONS; minus edge helpers deferred to aud_annotation_rendering_edges);
        <AudienceAnnotationBadge> (amber-100/amber-900 rounded-pill, t('methodology.annotationKind.<kind>')
        label, title={annotation.content}, data-annotation-kind seam, audience-prefixed testid);
        <AudienceAnnotationOverlay> (rAF-batched, anchored 30 px below node bounding box via
        ANNOTATION_ROW_OFFSET_Y = 30, cy.nodes() only). AudienceNodeData extended with annotations
        field; projectGraph stamps per-node from annotationIndex (mirrors axiomMarkIndex pattern).
        30 new Vitest cases: annotations.test.ts (7 a–g) + AnnotationBadge.test.tsx (5 a–e) +
        AnnotationOverlay.test.tsx (10 a–j) + projectGraph.test.ts (+5 v–z) + GraphView.test.tsx
        (+3 ss–uu). Playwright deferred to aud_visual_regression (audience surface not yet reachable).
        Tech-debt: aud_annotation_rendering_edges registered below.
        extract_cytoscape_projectors (tasks/27-shell-package.tji:101-108) now unblocked — audience
        is the third caller of projectAnnotations + groupAnnotationsByNode.
      ->8-
    }
    task aud_annotation_rendering_edges "Annotation rendering — edge-targeted annotations" {
      effort 1d
      allocate team
      complete 100
      depends !aud_annotation_rendering
      note -8<-
        Extend <AudienceAnnotationOverlay> to also render annotations whose target_edge_id is set.
        Imports groupAnnotationsByEdge from @a-conversa/shell (post-extract_cytoscape_projectors) or
        from apps/audience/src/graph/annotations.ts (pre-extract). Edges anchor badges at the
        rendered edge midpoint (cy.edges().forEach(edge => edge.midpoint())); AudienceEdgeData grows
        a readonly annotations array; tests pin the symmetric edge-rendering case. Inherits
        Decisions §1, §3, §4-modified-for-edges, §5, §6 from aud_annotation_rendering.
        Source-of-debt: tasks/refinements/audience/aud_annotation_rendering.md.
      ->8-
    }
    task aud_per_facet_visualization "Per-facet state visualization within a single node" {
      effort 2d
      allocate team
      complete 100
      depends !aud_proposed_styling, !aud_agreed_styling, !aud_disputed_styling
      note -8<-
        Refinement: tasks/refinements/audience/aud_per_facet_visualization.md

        DOM-overlay sibling of the Cytoscape canvas (pointer-events-none absolute inset-0);
        rAF-batched subscription to render/pan/zoom/resize/position/add-remove-data events;
        one [data-facet-pill-row] per node with non-empty facetStatuses, iterated in canonical
        wording → classification → substance order via FACET_RENDER_ORDER; anchor above the node
        bounding box (renderedBoundingBox().y1 - PILL_ROW_OFFSET_Y); <AudiencePerFacetPillOverlay>
        receives cy via a new useState<Core | null>(null) slot in <AudienceGraphView> paired with
        existing cyInstanceRef. 10 new PerFacetPillOverlay.test.tsx cases (a–j) + 3 new
        GraphView.test.tsx cases (ii–kk). Pixel-stability pin deferred to aud_visual_regression
        per Decision §6 (component not yet reachable through any route).
      ->8-
    }
    task aud_agreed_styling_mount_assertions "Mount-time Vitest cases for agreed-state computed style" {
      effort 0.25d
      allocate team
      complete 100
      depends !aud_agreed_styling, !aud_proposed_styling
      note -8<-
        Two deferred Vitest mount-time cases from aud_agreed_styling Constraints spec (cases 3 + 4):
        assert that a node / edge whose data.rollupStatus is 'agreed' carries computed
        border-color / line-color rgb(51, 65, 85) after one render tick, via
        cy.getElementById(id).style('border-color') / .style('line-color').
        Blocked on aud_proposed_styling landing the projection-time data.rollupStatus emission.
        Source: tasks/refinements/audience/aud_agreed_styling.md (Status block, 2026-05-27).
      ->8-
    }
    task aud_layout_engine "Configure layout algorithm tuned for clarity on video" {
      effort 2d
      allocate team
      complete 100
      depends !aud_cytoscape_init
      note -8<-
        Refinement: tasks/refinements/audience/aud_layout_engine.md

        Deterministic breadthfirst roots via selectDeterministicRoots (sort-stable lowest id among
        root candidates); broadcast-tuned SPACING_FACTOR 1.45 + PADDING 60; one-shot cy.fit on
        first non-empty render gated by hasFitOnceRef. 8 layoutOptions Vitest cases + 4 new
        GraphView cases (16 total). Pixel-stability pin deferred to aud_visual_regression per
        Decision §5 (component not yet reachable through any route).
      ->8-
    }
  }

