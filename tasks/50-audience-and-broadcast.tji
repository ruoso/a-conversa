      allocate team
      complete 100
      depends !aud_disputed_styling
      note -8<-
        Extract the module-scope STYLESHEET constant (and the BROADCAST_* typography exports that
        live alongside it in GraphView.tsx) into a sibling apps/audience/src/graph/stylesheet.ts
        module, keeping GraphView.tsx as a consumer. Three-sibling trigger fires with
        aud_disputed_styling (proposed + agreed + disputed selectors all land on the same file).
        Named by aud_clean_typography Decision §4. Source-of-debt: tasks/refinements/audience/
        aud_disputed_styling.md (Status block, 2026-05-27).
      ->8-
    }
    task aud_stylesheet_state_color_extraction "Hoist per-state hex literals into STATE_COLORS constant" {
      effort 0.25d
      allocate team
      complete 100
      depends !aud_disputed_styling
      note -8<-
        Hoist the per-state hex literals (#334155 for agreed, #e11d48 for disputed) into a
        STATE_COLORS named-export constant at module scope in GraphView.tsx (or in stylesheet.ts
        once aud_stylesheet_module_extraction lands). Three-sibling trigger fires with
        aud_disputed_styling. Named by aud_agreed_styling Decision §3. Source-of-debt:
        tasks/refinements/audience/aud_disputed_styling.md (Status block, 2026-05-27).
      ->8-
    }
    task aud_meta_disagreement_split "Meta-disagreement split rendering" {
      effort 1d
      allocate team
      complete 100
      depends !aud_cytoscape_init, !aud_proposed_styling, !aud_disputed_styling
      note -8<-
        Refinement: tasks/refinements/audience/aud_meta_disagreement_split.md

        Two new STYLESHEET selector entries: node[rollupStatus = 'meta-disagreement'] →
        border-style 'double' + border-color #7c3aed (violet-600, first per-state branch to
        override border-style: 'double'); edge[rollupStatus = 'meta-disagreement'] →
        line-color + target-arrow-color #7c3aed (solid violet, no line-style override —
        violet uniquely identifies meta-disagreement on the audience canvas). STATE_COLORS
