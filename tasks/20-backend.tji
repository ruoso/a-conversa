# 20 — Backend
#
# HTTP API, WebSocket protocol, authentication, session management, and
# everything the frontend surfaces talk to.

task backend "Backend" {
  task api_skeleton "API server skeleton" {
    depends foundation.repo_skeleton, foundation.dev_env
    task http_server "HTTP server bootstrap" {
      effort 1d
      allocate team
      complete 100
      note "Refinement: tasks/refinements/backend/http_server.md"
    }
    task error_handling "Centralized error handling and serialization" {
      effort 1d
      allocate team
      complete 100
      depends !http_server
      note "Refinement: tasks/refinements/backend/error_handling.md"
    }
    task request_logging "Structured request logging" {
      effort 0.5d
      allocate team
      complete 100
      depends !http_server
      note "Refinement: tasks/refinements/backend/request_logging.md"
    }
    task health_endpoint "GET /healthz health endpoint" {
      effort 0.25d
      allocate team
      complete 100
      depends !http_server
      note "Refinement: tasks/refinements/backend/health_endpoint.md"
    }
    task openapi_or_equivalent "Document API surface (OpenAPI or equivalent)" {
      effort 1d
      allocate team
      complete 100
      depends !http_server
      note "Refinement: tasks/refinements/backend/openapi_or_equivalent.md"
    }
    task serve_static_frontends "Serve frontend SPAs from the API server" {
      effort 1d
      allocate team
      complete 100
      depends !http_server
      note "Refinement: tasks/refinements/backend/serve_static_frontends.md"
    }
    task serve_static_frontends_path_collision_fix "Fix SPA-route collision with /sessions/:id API params validator" {
      effort 0.5d
      allocate team
      complete 100
      depends !serve_static_frontends
      note -8<-
        Refinement: tasks/refinements/backend/serve_static_frontends_path_collision_fix.md

        Source of debt: mod_create_session_form (this commit) — `/sessions/new` returned 400 from Fastify's GET /sessions/:id UUID params validator BEFORE the static-frontends SPA fallback could fire, forcing the moderator route to `/sessions/new/setup` as a 3-segment workaround. Any future 2-segment SPA route under /sessions/* will hit the same wall. Options: (a) move all session API routes under /api/sessions/*; (b) gate the params validator on the Accept header (validate UUID only for application/json, fall through to SPA for text/html); (c) explicitly exempt named segments like /sessions/new from validation. Choose under refinement.

        Surfaced via tech-debt registration policy in ORCHESTRATOR.md (commit b7c5ff0).
      ->8-
    }
    task serve_static_frontends_multi_surface "Extend static-frontends plugin to serve root app + per-surface bundles (ADR 0026)" {
      effort 0.5d
      allocate team
      complete 100
      depends !serve_static_frontends
      note -8<-
        Refinement: tasks/refinements/backend/serve_static_frontends_multi_surface.md

        Extends the serve_static_frontends plugin to: (a) serve apps/root/dist/index.html for non-API + non-/_surfaces/* paths; (b) serve apps/root/dist/assets/* for root's chunked assets; (c) serve per-surface bundles under /_surfaces/{moderator,participant,audience,replay-test}/[hash].js (plus CSS sidecars) with long-lived cache headers; (d) serve /_surfaces/manifest.json mapping each surface to its current hashed bundle URL. The root reads the manifest at boot. ADR 0026 — micro-frontend root app + lazy-loaded surface bundles.
      ->8-
    }
  }

  task auth "Authentication" {
    depends !api_skeleton, foundation.stack_decisions.auth_lib_decision
    task oauth_provider_config "Configure OAuth providers (generic + first-class)" {
      effort 2d
      allocate team
      complete 100
      note -8<-
        Generic OAuth client + wiring for Google, GitHub, GitLab.

        Refinement: tasks/refinements/backend/oauth_provider_config.md
      ->8-
    }
    task oauth_callback_handler "OAuth callback handler" {
      effort 1d
      allocate team
      complete 100
      depends !oauth_provider_config
      note "Refinement: tasks/refinements/backend/oauth_callback_handler.md"
    }
    task screen_name_collection "Screen-name collection on first auth" {
      effort 1d
      allocate team
      complete 100
      depends !oauth_callback_handler
      note "Refinement: tasks/refinements/backend/screen_name_collection.md"
    }
    task session_token_management "Issue and validate platform session tokens" {
      effort 2d
      allocate team
      complete 100
      depends !screen_name_collection
      note "Refinement: tasks/refinements/backend/session_token_management.md"
    }
    task no_profile_data_policy "Ensure no OAuth profile data is read or stored" {
      effort 0.5d
      allocate team
      complete 100
      depends !oauth_callback_handler
      note -8<-
        Audit + tests confirming we use OAuth purely as auth signal.

        Refinement: tasks/refinements/backend/no_profile_data_policy.md
      ->8-
    }
    task auth_middleware "Middleware enforcing authentication on protected endpoints" {
      effort 1d
      allocate team
      complete 100
      depends !session_token_management
      note "Refinement: tasks/refinements/backend/auth_middleware.md"
    }
    task auth_callback_new_user_browser_redirect "New-user OAuth callback must redirect the browser, not render raw JSON" {
      effort 0.5d
      allocate team
      complete 100
      depends !oauth_callback_handler, !screen_name_collection
      note -8<-
        Refinement: tasks/refinements/backend/auth_callback_new_user_browser_redirect.md

        Resolves the "raw JSON renders in browser after new-user callback" UX gap acknowledged in tasks/refinements/moderator-ui/mod_auth_flow.md (Decisions §last bullet, Open questions §1). GET /api/auth/callback today returns a 200 JSON body { sub, oauthSubject, userId, needsScreenName: true } on the new-user branch — in a real browser this dead-ends the user on a JSON view (confirmed by a tester 2026-05-16). Amends the handler to 302-redirect (pending cookie still set) to a SPA route that renders the screen-name form, and amends apps/root/src/App.tsx's ScreenNameRoute to render the form for a pending-cookie visitor whose /api/auth/me returns 401. Required for m_manual_lobby_smoke — a first-login human cannot reach the lobby today. Gated as priority 1000 to surface ahead of the rest of m_manual_lobby_smoke's open leaves.
      ->8-
    }
  }

  task session_management "Session management endpoints" {
    depends !api_skeleton, !auth
    task create_session_endpoint "POST /sessions" {
      effort 1d
      allocate team
      complete 100
      note "Refinement: tasks/refinements/backend/create_session_endpoint.md"
