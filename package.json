    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "cytoscape": "^3.30.0",
    "happy-dom": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "reactflow": "^11.11.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
