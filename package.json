{
  "name": "a-conversa",
  "version": "0.0.0",
  "private": true,
  "description": "Debate platform that classifies every statement and only proceeds when both sides agree on the classification.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "smoke:node": "tsx scripts/hello-world.ts",
    "smoke:react": "tsx scripts/hello-react.tsx",
    "smoke:reactflow": "tsx scripts/hello-reactflow.tsx",
    "smoke:cytoscape": "tsx scripts/hello-cytoscape.ts",
    "smoke:tailwind": "tsx scripts/hello-tailwind.ts",
    "seed": "tsx scripts/seed.ts",
    "unblocked": "tsx scripts/unblocked.ts",
    "migrate": "pnpm --filter @a-conversa/server run migrate",
    "test:smoke": "pnpm run build && vitest run tests/smoke packages apps",
    "test:behavior:smoke": "pnpm run build && node scripts/run-cucumber.mjs",
    "test:e2e:smoke": "pnpm run build && playwright test --config=playwright.config.ts",
    "test:e2e": "pnpm run build && playwright test --config=playwright.config.ts",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:migrations": "tsx scripts/lint-migrations.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "typecheck:tools": "tsc --noEmit -p tsconfig.tools.json",
    "typecheck:tests": "tsc --noEmit -p tests/tsconfig.json",
    "check": "pnpm run lint && pnpm run lint:migrations && pnpm run format:check && pnpm run typecheck && pnpm run typecheck:tools && pnpm run typecheck:tests",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,html,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@a-conversa/i18n-catalogs": "workspace:*",
    "@a-conversa/shared-types": "workspace:*",
    "@axe-core/playwright": "^4.10.2",
    "@cucumber/cucumber": "^12.8.3",
    "@electric-sql/pglite": "^0.4.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "cytoscape": "^3.30.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "happy-dom": "^20.8.9",
    "husky": "9.1.7",
    "i18next": "26.1.0",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-icu": "2.4.3",
    "intl-messageformat": "11.2.5",
    "jose": "6.1.0",
    "lint-staged": "17.0.4",
    "prettier": "^3.8.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "17.0.7",
    "reactflow": "^11.11.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.0",
    "ws": "^8.21.0"
  },
  "pnpm": {
    "overrides": {
      "vitest>vite": "^7.0.0",
      "vite-node>vite": "^7.0.0",
      "@vitest/mocker>vite": "^7.0.0",
      "esbuild": ">=0.28.1"
    }
  }
}
