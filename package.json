  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "smoke:node": "tsx scripts/hello-world.ts",
    "smoke:react": "tsx scripts/hello-react.tsx",
    "smoke:reactflow": "tsx scripts/hello-reactflow.tsx",
    "smoke:cytoscape": "tsx scripts/hello-cytoscape.ts",
    "smoke:tailwind": "tsx scripts/hello-tailwind.ts",
