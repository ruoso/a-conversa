# a-conversa — local-development environment template.
#
# Copy this file to `.env` (`cp .env.example .env`) before running
# `docker compose up`. Compose auto-loads `.env` from this directory.
#
# All values below are dev-only: the credentials, secrets, and host
# names are committed in this template specifically so a fresh clone
# can `make up` without further editing. Production secrets come from
# the `deployment.prod_secrets` task and never share material with this
# file.
#
# Conventions referenced here:
#   - Postgres credentials: infra/postgres/README.md (ADR 0016)
#   - OIDC client / issuer:  infra/authelia/README.md (ADR 0017)
#   - Compose wiring:         compose.yaml + ADR 0018
#
# `.env` is gitignored; `.env.example` is not. Keep new variables
# documented here in the same style (header + per-variable comment).

# --- Application ---

# Port the application's HTTP/WebSocket server binds inside the
# container. Compose publishes this on the host as `3000:3000`.
# If a frontend dev server (Vite, etc.) eventually claims its own
# port, this variable may need to be split or renamed; see
# foundation.dev_env.env_var_template Status notes.
APP_PORT=3000

# --- Postgres ---

# Database role name. Created by the upstream `postgres:16-alpine`
# entrypoint on first start; reused by the application's connection
# pool and any host-side `psql` sessions.
POSTGRES_USER=aconversa

# Password for POSTGRES_USER. Dev-only; production uses a rotated
# secret supplied by deployment.prod_secrets.
POSTGRES_PASSWORD=aconversa-dev

# Default database created on first start. Application schema lives
# here; per-test databases (created/dropped by Playwright fixtures)
# are owned by foundation.test_infra.test_db_provisioning and use
# this DB only as the connect-and-create-from target.
POSTGRES_DB=aconversa

# Full connection string consumed by the application. Host is the
# Compose service name (`postgres`), which resolves on the
# `aconversa` user-defined bridge network. When running the app
# outside the Compose stack (e.g., `pnpm dev` on the host), swap
# `postgres` for `localhost` — the host port 5432 is published.
DATABASE_URL=postgres://aconversa:aconversa-dev@postgres:5432/aconversa

# --- OIDC (Authelia) ---

# OIDC issuer URL used by the backend for discovery and token
# validation. Inside the Compose network the backend reaches Authelia
# via `http://authelia:9091`; from a host shell or browser use
# `http://localhost:9091`. The user-facing redirect endpoints are
# derived from this issuer; see infra/authelia/README.md.
OIDC_ISSUER_URL=http://authelia:9091

# Registered client ID. Must match `clients[0].client_id` in
# infra/authelia/configuration.yml — currently `aconversa-app-dev`.
OIDC_CLIENT_ID=aconversa-app-dev

# Plaintext client secret the application sends to Authelia's token
# endpoint (basic auth). Authelia stores the corresponding
# pbkdf2-sha512 hash in infra/authelia/configuration.yml; the two
# must stay in sync. To rotate, generate a new hash with
# `authelia crypto hash generate pbkdf2 --password 'NEW-SECRET'`,
# paste the hash into configuration.yml, and update this value.
# Dev-only; production secrets come from deployment.prod_secrets.
OIDC_CLIENT_SECRET=aconversa-app-dev-secret

# --- Sessions ---

# Symmetric secret used to sign / encrypt the application's session
# token (separate from Authelia's own session cookie). Dev-only —
# replace in production with a high-entropy value supplied by
# deployment.prod_secrets. Rotating in dev invalidates any open
# sessions on next restart.
SESSION_TOKEN_SECRET=dev-session-secret-change-me
