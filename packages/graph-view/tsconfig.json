{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "types": ["node"]
  },
  "include": ["src"],
  "references": [
    { "path": "../shared-types" },
    { "path": "../i18n-catalogs" },
    { "path": "../shell" }
  ]
}
